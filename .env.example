# 브라우저 응답 대기 시간 (밀리초, 기본값 30000)
BROWSER_TIMEOUT_MS=30000

# true: headless 모드 (로그인 필요 없는 공개 글만 가능)
# false: 브라우저 창을 열어 직접 로그인 후 사용 (기본값)
HEADLESS=false

# RAG 증분 색인(임베딩) — Voyage API 키. 무인 색인 시 자식 프로세스가 os.environ에서 읽는다.
VOYAGE_API_KEY=

# RAG 무인 색인 통지용 텔레그램 (trading-bot과 별개 봇/채널을 쓴다 — docs/OWNERSHIP.md)
# @BotFather로 만든 RAG 전용 봇 토큰과, 통지 받을 채널/채팅 id.
RAG_TELEGRAM_BOT_TOKEN=
RAG_TELEGRAM_CHAT_ID=
