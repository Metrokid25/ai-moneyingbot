{"answer": "DB \uadfc\uac70\uc0c1 \ud575\uc2ec\uc740 \uc804\uc138\uac00\uc728 \ud558\ub77d\uc774 \ubd80\ub3d9\uc0b0 \uac00\uaca9\uc5d0 \ubbf8\uce58\ub294 \uc601\ud5a5 \uc804\uc138\uac00\uc728 \ud558\ub77d\uc774 \ubd80\ub3d9\uc0b0 \uac00\uaca9\uc5d0 \ubbf8\uce58\ub294 \uc601\ud5a5 \uc804\uc138\uac00\uc728\uc774 \uac00\ud30c\ub974\uac8c \ud558\ub77d\ud55c\ub2e4\uc774\uace0, \uc608\ub97c\ub4e4\uba74 \ud22c\uae30\uc131 \uc790\uae08\uc774 \ubd80\ub3d9\uc0b0\uc5d0 \uc720\uc785\ub418\uba74 \ub9e4\ub9e4\uac00\uc640 \uc804\uc138\uac00\uc758 \uaca9\ucc28\ub294 \ud655\ub300\ub418\ub294\uac83\uc774 \uc0c1\uc2dd \uc774\ub2e4. \uac80\uc0c9\ub41c \uadfc\uac70\ub9cc \ub193\uace0 \ubcf4\uba74 \uc774 \ud310\ub2e8\uc740 \ubd80\ub3d9\uc0b0\uc740 \uc790\ubcf8\uc2dc\uc7a5\uc5d0\uc11c \uac70\ub798\ub418\ub294 \ucd5c\uace0\uac00\uc758 \uc0c1\ud488\uc774\ub2e4\uc640\ub3c4 \uc5f0\uacb0\ub41c\ub2e4. \uc138\ubd80 \uc870\uac74\uc740 source\uc640 text_preview \ubc94\uc704 \uc548\uc5d0\uc11c\ub9cc \uc81c\ud55c\uc801\uc73c\ub85c \ud574\uc11d\ud574\uc57c \ud55c\ub2e4.", "answer_status": "ok", "db_only": true, "missing_evidence": [], "question": "\ubd80\ub3d9\uc0b0 \ud558\ub77d\uc7a5\uc5d0\uc11c \uc804\uc138\uac00\uc728\uc740 \uc65c \uc911\uc694\ud55c\uac00?", "question_id": "research_q_005", "topic": "\ubd80\ub3d9\uc0b0/\uc804\uc138\uac00\uc728/\ub300\ucd9c", "unsupported_claims": [], "used_sources": [{"article_id": 10481, "chunk_id": "10481:0", "rank": 1, "source_ref": "article_id:10481:chunk_id:10481:0", "title": "\uc804\uc138\uac00\uc728 \ud558\ub77d\uc774 \ubd80\ub3d9\uc0b0 \uac00\uaca9\uc5d0 \ubbf8\uce58\ub294 \uc601\ud5a5"}, {"article_id": 152119, "chunk_id": "152119:0", "rank": 2, "source_ref": "article_id:152119:chunk_id:152119:0", "title": "\uc804\uc138\uac00\uc728\uc774 \ub9e4\ub9e4\uac00\uc758 60%\ub97c \ub118\uc5b4\uc11c\uc9c0 \ubabb\ud558\uba74 \uc8fc\ud0dd\uac70\ub798 \ud65c\uc131\ud654\uac00.........................................."}, {"article_id": 15385, "chunk_id": "15385:1", "ra